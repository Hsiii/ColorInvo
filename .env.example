# iOS device and release automation. Keep real values in a private .env
# or .env.local file. .env.local takes precedence and is gitignored.
# Required for bun run ios:device, ios:archive, and ios:upload.
# If unset here, scripts can reuse ../OnTrack/.env's APPLE_TEAM_ID.
APPLE_TEAM_ID=

# Optional App Store Connect API key credentials for headless auth.
# Leave these empty to use the Apple account signed in through Xcode.
# ASC_API_KEY is accepted as an alias for ASC_KEY_ID.
ASC_API_KEY=
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_KEY_PATH=

# Optional device override. Leave empty to auto-detect a connected device.
IOS_DEVICE_ID=

# Optional App Store Connect screenshot overrides.
IOS_SCREENSHOT_OUTPUT_DIR=
IOS_SCREENSHOT_DEVICE_NAME=
IOS_SCREENSHOT_DEVICE_TYPE=
IOS_SCREENSHOT_RUNTIME=

IOS_BUNDLE_ID=dev.hsichen.colorinvo

# Android release signing lives in apps/android/keystore.properties. Keep the
# keystore and populated properties file private.
ANDROID_VERSION_NAME=0.1.0
ANDROID_VERSION_CODE=1
ANDROID_PACKAGE_NAME=dev.hsichen.colorinvo

# Google Play Developer API service-account key and release defaults.
PLAY_SERVICE_ACCOUNT_JSON=
PLAY_TRACK=internal
PLAY_RELEASE_STATUS=completed
PLAY_UPLOAD_IMAGES=false
PLAY_UPLOAD_SCREENSHOTS=false
