# iOS device and release automation. Keep real values in a private .env
# or .env.local file. .env.local takes precedence and is gitignored.
# Required for bun run ios:device, ios:archive, and ios:upload.
# If unset here, scripts can reuse ../OnTrack/.env's APPLE_TEAM_ID.
APPLE_TEAM_ID=

# App Store Connect API key credentials for archives and uploads.
# ASC_API_KEY is accepted as an alias for ASC_KEY_ID.
ASC_API_KEY=
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_KEY_PATH=

# Optional device override. Leave empty to auto-detect a connected device.
IOS_DEVICE_ID=

IOS_BUNDLE_ID=dev.hsichen.colorinvo
