# iOS device and release automation. Keep real values in a private .env file.
# Required for bun run ios:device, ios:archive, and ios:upload.
# If unset here, scripts can reuse ../OnTrack/.env's APPLE_TEAM_ID.
APPLE_TEAM_ID=
ASC_KEY_PATH=
ASC_KEY_ID=
ASC_ISSUER_ID=
IOS_BUNDLE_ID=dev.hsichen.colorinvo
